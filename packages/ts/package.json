{
  "name": "@reallyme/crypto",
  "version": "0.3.0",
  "description": "ReallyMe crypto SDK for TypeScript/JavaScript with an explicit, pinned provider set.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reallyme/crypto.git",
    "directory": "packages/ts"
  },
  "homepage": "https://github.com/reallyme/crypto#readme",
  "bugs": {
    "url": "https://github.com/reallyme/crypto/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./proto": {
      "types": "./dist/proto.d.ts",
      "default": "./dist/proto.js"
    },
    "./wasm/reallyme_crypto_wasm.js": {
      "types": "./dist/wasmModuleTypes.d.ts",
      "default": "./dist/wasm/reallyme_crypto_wasm.js"
    },
    "./wasm/reallyme_crypto_wasm_bg.wasm": {
      "default": "./dist/wasm/reallyme_crypto_wasm_bg.wasm"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/clean-dist.mjs && npm run build:wasm && tsc",
    "build:ts": "tsc",
    "build:wasm": "node scripts/build-wasm.mjs",
    "pack:check": "node scripts/check-pack.mjs",
    "prepack": "npm run build",
    "prepublishOnly": "npm test && npm run pack:check",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test \"test/*.test.mjs\""
  },
  "dependencies": {
    "@bufbuild/protobuf": "2.12.1",
    "@noble/curves": "2.2.0",
    "@noble/hashes": "2.2.0",
    "@reallyme/codec": "0.2.0"
  },
  "devDependencies": {
    "typescript": "5.8.3"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
