{
  "schemaVersion": 1,
  "description": "Shared fail-closed negative vector metadata. Each case references a committed positive vector and defines the deterministic mutation plus the typed failure contract every executable lane must assert.",
  "cases": [
    {
      "id": "hpke-p256-short-encapsulated-key",
      "algorithm": "DHKEM-P256-HKDF-SHA256-HKDF-SHA256-AES-256-GCM",
      "operation": "hpke_open",
      "positiveVector": "hpke.json",
      "mutation": "truncate encapsulated_key by one byte before open",
      "expected": {
        "facadeError": "invalidInput",
        "wireBranch": "primitive",
        "reason": "CRYPTO_ERROR_REASON_PRIMITIVE_INVALID_LENGTH"
      },
      "lanes": ["rust-native", "swift-native", "kotlin-jvm-native", "typescript-wasm"]
    },
    {
